    }
  ],
  "shortcuts": [
    {
      "name": "New Blueprint",
      "short_name": "Blueprint",
      "description": "Create a new architectural blueprint",
      "url": "/?action=blueprint",
      "icons": [
        {
          "src": "/icons/blueprint-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Structure Analysis",
      "short_name": "Analysis",
      "description": "Analyze building structure",
      "url": "/?action=analysis",
      "icons": [
        {
          "src": "/icons/analysis-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Material Selection",
      "short_name": "Materials",
      "description": "Choose sustainable materials",
      "url": "/?action=materials",
      "icons": [
        {
          "src": "/icons/materials-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+architect",
      "url": "/?action=protocol&data=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/?action=file",
      "accept": {
        "image/*": [
          ".jpg",
          ".jpeg",
          ".png",
          ".gif",
          ".webp"
        ],
        "application/pdf": [
          ".pdf"
        ],
        "text/*": [
          ".txt",
          ".md"
        ]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "related_applications": [],
  "prefer_related_applications": false
}